# Variáveis de Configuração - Pipeline de Detecção de Fraude

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fraud_detection
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9093
KAFKA_TOPIC_TRANSACOES=transacoes
KAFKA_TOPIC_ALERTAS=alertas
KAFKA_GROUP_ID=fraud-detector-group

# Simulador
SIMULATOR_TPS=10
SIMULATOR_SUSPICIOUS_RATIO=0.08

# Detector - Limiares
LIMITE_VALOR=5000.00
LIMITE_TRANSACOES_HORA=10
LIMITE_ACUMULADO_DIA=50000.00
JANELA_FREQUENCIA=60
HORA_INICIO_ATIPICO=23
HORA_FIM_ATIPICO=5
LIMITE_DISTANCIA_KM=300.0